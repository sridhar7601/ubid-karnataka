flowchart TB
    subgraph Sources["SOURCE SYSTEMS (40+ siloed registries)"]
      GST["GST<br/>(440 records)"]
      MCA["MCA<br/>(351 records)"]
      UDYAM["Udyam<br/>(440 records)"]
      OTHERS["...Shop · Factories · Labour ·<br/>KSPCB · ESCOMs · Fire · Food Safety"]
    end

    subgraph Resolve["ENTITY RESOLUTION (Part A)"]
      BLOCK["Block by pincode<br/>(reduces O(N²) candidates)"]
      DETERM["Deterministic Match<br/>PAN / GSTIN / Udyam exact<br/>(score = 1.0)"]
      PROB["Probabilistic Match<br/>rapidfuzz Jaro-Winkler<br/>+ token-sort"]
      TIER["3-Tier Confidence<br/>HIGH ≥ 0.9 (auto-link)<br/>MEDIUM 0.7–0.9 (review)<br/>LOW < 0.7 (separate)"]
    end

    subgraph Lifecycle["LIFECYCLE INFERENCE (Part B)"]
      EVENTS["Event Stream<br/>(2,723 events: filing, inspection,<br/>renewal, payment, audit, closure)"]
      RULES["Rule Engine<br/>Active / Dormant / Closed<br/>(12-month / 24-month thresholds)"]
      CONFLICT["Cross-Source Conflict Detector<br/>(GST=Active vs MCA=Closed)"]
    end

    subgraph Storage["UBID STORE"]
      UBID["UBID<br/>(685 unified entities,<br/>anchored to PAN/GSTIN)"]
      AUDIT["Reviewer Audit Trail<br/>(confirm / reject decisions,<br/>fully reversible)"]
    end

    subgraph AI["AZURE GPT-4.1 NARRATION (grounded)"]
      AI_LINK["AI Linkage Rationale<br/>(per pair)"]
      AI_LIFE["AI Lifecycle Verdict<br/>(per UBID)"]
      AI_QUERY["AI Query Summary<br/>(per Smart Query result)"]
      AI_BRIEF["AI Morning Briefing<br/>(dashboard)"]
    end

    subgraph UI["FRONTEND (React + Vite)"]
      DASH["/ Dashboard"]
      RES["/resolution<br/>(reviewer queue)"]
      ENT["/entities · /entity/&lt;UBID&gt;"]
      INS["/insights<br/>(Smart Query)"]
    end

    GST --> BLOCK
    MCA --> BLOCK
    UDYAM --> BLOCK
    OTHERS -.future.-> BLOCK

    BLOCK --> DETERM
    BLOCK --> PROB
    DETERM --> TIER
    PROB --> TIER
    TIER --> UBID

    EVENTS --> RULES
    RULES --> CONFLICT
    CONFLICT --> UBID
    UBID --> AUDIT

    UBID --> AI_LINK
    UBID --> AI_LIFE
    UBID --> AI_QUERY
    UBID --> AI_BRIEF

    AI_LINK --> RES
    AI_LIFE --> ENT
    AI_QUERY --> INS
    AI_BRIEF --> DASH

    UBID --> RES
    UBID --> ENT
    UBID --> INS

